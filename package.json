{
  "name": "rewind-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js && tailwindcss -i ./static/css/input.css -o ./static/dist/main.css --minify",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "extensions:sync": "node scripts/sync-extension-common.js",
    "screenshots:readme": "node scripts/capture-readme-screenshots.js",
    "video:readme": "node scripts/record-readme-video.js",
    "video:stitch": "node scripts/stitch-readme-video.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "esbuild": "^0.20.2",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "d3": "^7.9.0",
    "mediabunny": "^1.45.2",
    "puppeteer": "^24.43.1"
  }
}
